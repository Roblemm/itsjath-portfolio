---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/work/WorkCard.astro';
import { EDUCATION } from '../../utils/site';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.flagship !== b.data.flagship) return a.data.flagship ? -1 : 1;
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.title.localeCompare(b.data.title);
});

const flagship = projects.find((p) => p.data.flagship);
const builds = projects.filter((p) => p.data.category === 'software' || p.data.category === 'platform');
const creative = projects.filter((p) => p.data.category === 'creative');

const proof = [
  { value: '78M+', label: 'Plays & views' },
  { value: '1,200+', label: 'Platform users' },
  { value: '30+', label: 'Creators led' },
  { value: '500%', label: 'Onboarding lift' },
];
---

<BaseLayout
  title="Work"
  description="Flagship games, production platforms, and full-stack systems — proof that Jath ships work people notice."
>
  <div class="container section page-enter" data-page-content>
    <header class="work-hero">
      <p class="meta work-hero__eyebrow">Selected work</p>
      <h1 class="work-hero__title">I ship work millions of people play — and the systems behind it.</h1>
      <p class="work-hero__lead">
        {EDUCATION.school} · Computer Science &amp; Business Analytics · founder of
        ForestlyGames and ForestlyDevs. Recruiters and founders should see one thread:
        I take unclear problems from concept to production — creative reach, platform growth,
        and full-stack engineering.
      </p>
    </header>

    <div class="work-proof" aria-label="Career proof points">
      {
        proof.map((item) => (
          <div class="work-proof__item">
            <span class="work-proof__value">{item.value}</span>
            <span class="work-proof__label">{item.label}</span>
          </div>
        ))
      }
    </div>

    {
      flagship && (
        <a href={`/work/${flagship.id}/`} class="work-spotlight">
          <div
            class="work-spotlight__visual"
            style={flagship.data.cover ? `background-image: url('${flagship.data.cover}')` : undefined}
          />
          <div class="work-spotlight__body">
            <p class="work-spotlight__tag">Flagship · {flagship.data.status}</p>
            <h2 class="work-spotlight__title">{flagship.data.title}</h2>
            <p class="lead">{flagship.data.highlight ?? flagship.data.one_line_summary}</p>
            {
              flagship.data.metrics && (
                <div class="work-spotlight__metrics">
                  {flagship.data.metrics.map((m) => (
                    <span class="work-spotlight__metric">
                      <strong>{m.value}</strong> {m.label}
                    </span>
                  ))}
                </div>
              )
            }
            <span class="link-arrow">Read the full case study →</span>
          </div>
        </a>
      )
    }

    <section class="work-section" aria-labelledby="work-creative">
      <div class="work-section__head">
        <h2 id="work-creative" class="work-section__title">Games &amp; creative</h2>
        <p class="work-section__note">
          Studio founder. Horror obbies, strategy builders, live co-op — shipped with creator
          partnerships that drove breakout reach.
        </p>
      </div>
      <div class="work-grid">
        {creative.filter((p) => !p.data.flagship).map((project) => <WorkCard project={project} />)}
      </div>
    </section>

    <section class="work-section" aria-labelledby="work-builds">
      <div class="work-section__head">
        <h2 id="work-builds" class="work-section__title">Platforms &amp; engineering</h2>
        <p class="work-section__note">
          Production systems recruiters can verify — ops platforms, marketplaces, Spring Boot APIs,
          and measurable growth outcomes.
        </p>
      </div>
      <div class="work-grid">
        {builds.map((project) => <WorkCard project={project} featured={project.data.featured} />)}
      </div>
    </section>
  </div>
</BaseLayout>
