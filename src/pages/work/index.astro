---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/work/WorkCard.astro';
import { EDUCATION } from '../../utils/site';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.flagship !== b.data.flagship) return a.data.flagship ? -1 : 1;
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.title.localeCompare(b.data.title);
});

const featuredEngineering = projects.find((p) => p.id === 'forestlygames-operations-platform');
const featuredProduct = projects.find((p) => p.id === 'forestlygames');
const featuredProjectIds = new Set([featuredEngineering?.id, featuredProduct?.id].filter(Boolean));
const productChapterIds = [
  'boss-battles',
  'roempires',
  'encaved',
  'escape-bruno-head',
  'evil-pets',
];
const productChapters = productChapterIds
  .map((id) => projects.find((project) => project.id === id))
  .filter((project) => project !== undefined);
const studioChapterIds = new Set(productChapterIds);

const visibleProductChapterIds = new Set([
  'boss-battles',
  'roempires',
  'encaved',
  'escape-bruno-head',
  'evil-pets',
]);

const selectedProjects = projects.filter(
  (project) => !featuredProjectIds.has(project.id) && !studioChapterIds.has(project.id),
);

const proof = [
  { value: '78M+', label: 'Portfolio plays & views' },
  { value: '6', label: 'Games delivered' },
  { value: '30+', label: 'Creator collaborations' },
  { value: '4,000', label: 'Community members' },
];
---

<BaseLayout
  title="Work"
  description="Featured engineering and product work from Jathniel Ahonsi: studio operations, shipped games, communities, and full-stack systems."
>
  <div class="container section page-enter" data-page-content>
    <header class="work-hero">
      <p class="meta work-hero__eyebrow">Selected work</p>
      <div class="work-hero__layout">
        <h1 class="work-hero__title">I build products people use, play, and keep coming back to.</h1>
        <p class="work-hero__lead">
          <span class="work-hero__lead-context">
            {EDUCATION.school} &middot; Computer Science &amp; Business Analytics
          </span>
          <span class="work-hero__lead-main">
            Founder of ForestlyGames and ForestlyDevs, turning messy ideas into shipped products
            where engineering, operations, community, and distribution work together.
          </span>
        </p>
      </div>
    </header>

    <div class="work-proof" aria-label="Career proof points">
      {
        proof.map((item) => (
          <div class="work-proof__item">
            <span class="work-proof__value">{item.value}</span>
            <span class="work-proof__label">{item.label}</span>
          </div>
        ))
      }
    </div>

    <section class="work-section" aria-labelledby="featured-work">
      <div class="work-section__head">
        <h2 id="featured-work" class="work-section__title">Featured work</h2>
        <p class="work-section__note">
          Two sides of the same portfolio: the product studio and the engineering system behind it.
        </p>
      </div>

      <div class="work-featured-grid">
        {
          featuredProduct && (
            <div class="work-featured work-featured--product">
              <p class="work-featured__label">
                <span class="work-featured__context">ForestlyGames</span>
                <span class="work-featured__side-pill work-featured__side-pill--product">Product</span>
              </p>
              <WorkCard project={featuredProduct} featured />
              <div class="work-product-chapters" aria-label="ForestlyGames game chapters">
                {productChapters
                  .filter((chapter) => visibleProductChapterIds.has(chapter.id))
                  .map((chapter) => (
                    <a href={`/work/${chapter.id}/`} class="work-product-chapter">
                      {chapter.data.cover && (
                        <img
                          src={chapter.data.cover}
                          alt=""
                          class="work-product-chapter__img"
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <span class="work-product-chapter__body">
                        <span class="work-product-chapter__title">{chapter.data.title}</span>
                        <span class="work-product-chapter__meta">{chapter.data.status}</span>
                      </span>
                    </a>
                  ))}
              </div>
            </div>
          )
        }
        {
          featuredEngineering && (
            <div class="work-featured">
              <p class="work-featured__label">
                <span class="work-featured__context">ForestlyGames</span>
                <span class="work-featured__side-pill work-featured__side-pill--software">Software</span>
              </p>
              <WorkCard project={featuredEngineering} featured />
            </div>
          )
        }
      </div>
    </section>

    <section class="work-section" aria-labelledby="selected-work">
      <div class="work-section__head">
        <h2 id="selected-work" class="work-section__title">Selected supporting work</h2>
        <p class="work-section__note">
          Platform builds, community systems, product research, and brand work that fill in the range.
        </p>
      </div>
      <div class="work-grid">
        {selectedProjects.map((project) => <WorkCard project={project} />)}
      </div>
    </section>
  </div>
</BaseLayout>
