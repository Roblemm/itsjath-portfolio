---
import { NAV_LINKS, SITE } from '../../utils/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/resume.pdf') return false;
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href.replace(/\/$/, ''));
}
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a href="/" class="wordmark" aria-label={`${SITE.name} home`}>
      {SITE.name}<span class="wordmark__dot">.</span>
    </a>

    <nav class="nav__center" aria-label="Primary">
      <ul class="nav__links">
        {
          NAV_LINKS.map((link, i) => (
            <li>
              <a
                href={link.href}
                class="nav__link"
                aria-current={isActive(link.href) ? 'page' : undefined}
                {...(link.href.endsWith('.pdf') ? { target: '_blank', rel: 'noopener' } : {})}
              >
                <span class="nav__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="nav__label">{link.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a href="/contact/" class="nav__cta">
      Let's connect
      <span aria-hidden="true">↗</span>
    </a>

    <button type="button" class="nav__toggle" data-nav-toggle aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </div>
</header>
