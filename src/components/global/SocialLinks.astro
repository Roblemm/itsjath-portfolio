---
import { SITE } from '../../utils/site';
---

<div class="social-links" role="list">
  <a href={SITE.github} class="link-arrow" target="_blank" rel="noopener noreferrer" role="listitem">
    GitHub →
  </a>
  <a href={SITE.linkedin} class="link-arrow" target="_blank" rel="noopener noreferrer" role="listitem">
    LinkedIn →
  </a>
</div>

<style>
  .social-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
</style>
